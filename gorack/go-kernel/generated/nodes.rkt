(module+ test
  (require rackunit)
  (define expression-value
    (make-ir-node #f "go/ast" "Ident" '(("Name" . "x"))))
  (define statement-value (make-go:BlockStmt #:list '()))
  (define child-statement
    (make-ir-node #f "go/ast" "ExprStmt"
                  (list (list "X" expression-value))))
  (define one-child-block
    (make-go:BlockStmt #:list (list child-statement)))
  (define declaration-value
    (make-ir-node #f "go/ast" "FuncDecl" '()))
  (define specification-value
    (make-ir-node #f "go/ast" "ImportSpec" '()))
  (define future-official-value
    (make-ir-node #f "go/ast" "FutureNode" '()))
  (define canonical-basic
    (make-ir-node #f "go/ast" "BasicLit"
                  (list (list "ValuePos" ir-null-value)
                        (list "ValueEnd" ir-null-value)
                        (list "Kind" (ir-token "INT"))
                        (list "Value" "1"))))
  (define canonical-channel
    (make-ir-node #f "go/ast" "ChanType"
                  (list (list "Dir"
                              (enum-value "go/ast.ChanDir" '(SEND))))))
  (define canonical-field-list
    (make-ir-node #f "go/ast" "FieldList"
                  (list (list "List" ir-null-value))))
  (define false-empty-field-list
    (make-ir-node #f "go/ast" "FieldList"
                  (list (list "List" #f))))
  (define canonical-package
    (make-ir-node #f "go/ast" "Package"
                  (list (list "Files" ir-null-value))))
  (define canonical-null-child
    (make-ir-node #f "go/ast" "BinaryExpr"
                  (list (list "X" ir-null-value))))
  (check-true (go:Node? expression-value))
  (check-true (go:Expr? expression-value))
  (check-false (go:Stmt? expression-value))
  (check-true (go:Stmt? statement-value))
  (check-true (go:Decl? declaration-value))
  (check-true (go:Spec? specification-value))
  (check-true (go:Node? future-official-value))
  (check-false (go:Expr? future-official-value))
  (check-equal? (go:BlockStmt-list statement-value) '())
  (check-equal? (go:BlockStmt-list one-child-block)
                (list child-statement))
  (check-equal? (go:BasicLit-kind canonical-basic) "INT")
  (check-false (go:BasicLit-value-pos canonical-basic))
  (check-equal? (go:ChanType-dir canonical-channel) '("SEND"))
  (check-equal? (go:FieldList-list canonical-field-list) '())
  (check-equal? (go:FieldList-list false-empty-field-list) '())
  (check-equal? (go:Package-files canonical-package) (hash))
  (check-false (go:BinaryExpr-x canonical-null-child)))
