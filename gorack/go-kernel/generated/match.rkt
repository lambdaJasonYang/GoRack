      (append
       (if (hash-has-key? requested '#:semicolon)
           (list #`(and
                    (? (lambda (value) (ir-node-has-field? value "Semicolon")))
                    (app go:EmptyStmt-semicolon #,(hash-ref requested '#:semicolon))))
           '())
       (if (hash-has-key? requested '#:implicit)
           (list #`(and
                    (? (lambda (value) (ir-node-has-field? value "Implicit")))
                    (app go:EmptyStmt-implicit #,(hash-ref requested '#:implicit))))
           '())
       ))
    (with-syntax ([(field-clause ...) clauses])
      #'(and
         (? go:EmptyStmt?)
         field-clause ...
         )))
  (make-rename-transformer #'make-go:EmptyStmt))

