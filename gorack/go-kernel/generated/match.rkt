(module+ test
  (require rackunit
           "../node.rkt")
  ;; A partial match must not read fields omitted by its keyword pattern. This
  ;; is what lets a newly generated matcher consume an older named-field node.
  (define older-binary
    (make-ir-node #f "go/ast" "BinaryExpr" '(("X" . left))))
  (check-equal?
   (match older-binary
     [(go:BinaryExpr #:x value) value]
     [_ #f])
   'left)
  (check-equal?
   (match older-binary
     [(go:BinaryExpr #:op value) value]
     [_ 'fallback])
   'fallback))
